                "  pm.environment.set('ordenCompraId', String(id));",
                "  pm.test('N07 tiene _links', () => pm.expect(j[0]._links.self.href).to.be.a('string'));",
                "} else {",
                "  console.log('Sin stock bajo mínimo: array vacío es válido');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenEmpleado}}" }],
            "url": "{{baseUrl}}/api/ordenes-compra/generar-automaticas",
            "description": "Genera órdenes si stock <= stockMinimo. Tras N03/N04 es más probable que haya resultados."
          }
        },
        {
          "name": "N08 GET órdenes de compra (EMPLEADO) → 200 OK",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('N08 → 200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('N08 _links.self', () => pm.expect(j._links.self.href).to.include('/api/ordenes-compra'));",
                "pm.test('N08 page', () => pm.expect(j.page).to.exist);",
                "if (j._embedded) {",
                "  const list = j._embedded.ordenCompraResponseDTOList || Object.values(j._embedded)[0];",
                "  if (list && list[0] && list[0].id && !pm.collectionVariables.get('ordenCompraId')) {",
                "    pm.collectionVariables.set('ordenCompraId', String(list[0].id));",
                "    pm.environment.set('ordenCompraId', String(list[0].id));",
                "  }",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenEmpleado}}" }],
            "url": "{{baseUrl}}/api/ordenes-compra?page=0&size=5"
          }
        },
        {
          "name": "N09 POST confirmar recepción orden (EMPLEADO) → 200 OK",
          "event": [{
            "listen": "prerequest",
            "script": {
              "exec": [
                "const id = pm.collectionVariables.get('ordenCompraId') || pm.environment.get('ordenCompraId');",
                "if (!id) { console.warn('ordenCompraId vacío: ejecuta N07/N08 primero o fuerza stock bajo mínimo'); }"
              ],
              "type": "text/javascript"
            }
          }, {
            "listen": "test",
            "script": {
              "exec": [
                "const id = pm.collectionVariables.get('ordenCompraId') || pm.environment.get('ordenCompraId');",
                "if (!id) {",
                "  pm.test('N09 omitido (sin ordenCompraId)', () => pm.expect(true).to.be.true);",
                "} else {",
                "  pm.test('N09 → 200 OK', () => pm.response.to.have.status(200));",
                "  const j = pm.response.json();",
                "  pm.test('N09 estado RECIBIDA', () => pm.expect(j.estado).to.eql('RECIBIDA'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenEmpleado}}" }],
            "url": "{{baseUrl}}/api/ordenes-compra/{{ordenCompraId}}/confirmar-recepcion",
            "description": "Incrementa stock en sucursal. Requiere ordenCompraId de N07/N08."
          }
        },
        {
          "name": "N10 GET reporte rotación productos (EMPLEADO) → 200 OK",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('N10 → 200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('N10 es array', () => pm.expect(j).to.be.an('array'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenEmpleado}}" }],
            "url": "{{baseUrl}}/api/reportes/rotacion-productos",
            "description": "Más/menos vendidos (ventas + pedidos)"
          }
        },
        {
          "name": "N11 POST promoción (GERENTE) → 200 OK",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('N11 → 200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('N11 _links.self', () => pm.expect(j._links.self.href).to.include('/api/promociones/'));",
                "pm.test('N11 descuento', () => pm.expect(j.descuentoPorcentaje).to.eql(15));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenGerente}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Promo Postman S9\",\n  \"descripcion\": \"Descuento de evidencia EFT\",\n  \"descuentoPorcentaje\": 15,\n  \"fechaInicio\": \"2026-01-01T00:00:00.000Z\",\n  \"fechaFin\": \"2026-12-31T23:59:59.000Z\",\n  \"activa\": true,\n  \"producto\": { \"id\": 1 },\n  \"sucursal\": { \"id\": 1 }\n}"
            },
            "url": "{{baseUrl}}/api/promociones"
          }
        }
      ]
    }
  ]
